# shared.env — Config dùng chung cho 3 folder (bell/, minhtran/, Vu/).
#
# File này commit được vào git (không nằm trong .gitignore vì không match .env*).
# Khi hôm thi đổi IP / port / MSSV, chỉ cần sửa 1 file duy nhất ở đây.
#
# Mỗi folder đã được sửa để load_dotenv() trỏ về file này.

# === Sinh viên ===============================================================
STUDENT_ID=B22DCDT171

# === Teacher Server ==========================================================
# Đổi IP theo bảng thông báo hôm thi (nhớ KHÔNG có dấu / ở cuối).
TEACHER_BASE_URL=http://192.168.50.218:8000/api/v1
TEACHER_PROXY_BASE_URL=http://192.168.50.218:8000/api/v1/proxy

# === Student Server (máy của bạn) ============================================
# SERVER_PUBLIC_IP: IP LAN của máy đang chạy student server.
#   - Để TRỐNG để code tự dò IP qua socket (đa số trường hợp đủ dùng).
#   - Hoặc set cứng (vd 192.168.50.229) nếu máy có nhiều card mạng (Wifi + LAN).
SERVER_PUBLIC_IP=
SERVER_PORT=5000
